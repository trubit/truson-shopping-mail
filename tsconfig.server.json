{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,

    "outDir": "./dist/server",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@server/*": ["./server/src/*"]
    },

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["server/src", "src/shared"],
  "exclude": ["node_modules", "dist"]
}
