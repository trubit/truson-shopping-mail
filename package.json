{
  "name": "truson-shopping-mail",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run kill:ports && concurrently --kill-others-on-fail -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "wait-on http://localhost:5000/health --timeout 30000 && vite",
    "dev:server": "tsx watch server/src/index.ts",
    "client": "vite",
    "server": "tsx watch server/src/index.ts",
    "kill:ports": "node -e \"const {execSync}=require('child_process');try{execSync('npx kill-port 5000 5173',{stdio:'ignore'})}catch{}\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:server": "vitest run --config vitest.config.server.ts",
    "test:server:watch": "vitest --config vitest.config.server.ts",
    "test:server:coverage": "vitest run --coverage --config vitest.config.server.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:server"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@mui/material": "^9.1.1",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.40.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "streamifier": "^0.1.1",
    "stripe": "^22.3.0",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
